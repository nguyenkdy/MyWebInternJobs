PORT=3000
MONGODB_URI=mongodb://<user>:<password>@<host1>:27017,<host2>:27017,<host3>:27017/<db>?ssl=true&replicaSet=<replicaSet>&authSource=admin&appName=<appName>
SESSION_SECRET=replace-me-with-a-long-random-string

# AWS S3 (for intern avatar + cover upload)
AWS_REGION=ap-southeast-1
S3_BUCKET_NAME=your-bucket-name

# AWS credentials (use IAM user keys for local dev)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# If true, objects are public and we use a normal S3 URL.
# If false, we generate signed URLs when rendering the profile.
S3_PUBLIC=false
S3_PUBLIC_URL_BASE=
S3_SIGNED_EXPIRES_SECONDS=3600

