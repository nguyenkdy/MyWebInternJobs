<%-
  include("../layout", {
    title,
    currentUser,
    body: `
      <section class="page">
        <h1>Interns</h1>
        <form class="filters" method="get" action="/interns">
          <input class="input" name="q" placeholder="Search intern name, university, major, skills" value="${q ? String(q).replaceAll('"', "&quot;") : ""}" />
          <span class="muted" style="align-self:center;">Browse</span>
          <button class="button" type="submit">Search</button>
        </form>

        <div class="jobs">
          ${
            interns.length
              ? interns
                  .map(
                    (i) => `
                      <a class="job" href="/interns/${i._id}" style="text-decoration:none;">
                        <div class="job__top">
                          <div style="display:flex; align-items:center; gap:12px;">
                            <div style="width:40px; height:40px; border-radius:12px; overflow:hidden; border:1px solid var(--border); background: rgba(0,0,0,0.2); flex: 0 0 auto;">
                              ${
                                i.avatar
                                  ? `<img src="${i.avatar}" alt="Avatar" style="width:100%; height:100%; object-fit:cover; display:block;" />`
                                  : `<div style="width:100%; height:100%; display:grid; place-items:center; font-weight:800;">${(i.fullName || i.email || "?").slice(0, 1).toUpperCase()}</div>`
                              }
                            </div>
                            <div class="job__title">${i.fullName || i.email}</div>
                          </div>
                          <span class="badge">intern</span>
                        </div>
                        <div class="job__meta">
                          <span>${i.university || "Unknown university"}</span>
                          <span class="dot">•</span>
                          <span>${i.major || "Major"}</span>
                        </div>
                      </a>
                    `
                  )
                  .join("")
              : `<div class="muted">No interns found.</div>`
          }
        </div>
      </section>
    `,
  })
%>

