<%-
  include("../layout", {
    title,
    currentUser,
    body: `
      <section class="page">
        <h1>Find internships</h1>
        <form class="filters" method="get" action="/jobs">
          <input class="input" name="q" placeholder="Search title, company, location" value="${q ? String(q).replaceAll('"', "&quot;") : ""}" />
          <select class="input" name="type">
            <option value="" ${!type ? "selected" : ""}>Any type</option>
            <option value="internship" ${type === "internship" ? "selected" : ""}>Internship</option>
            <option value="part-time" ${type === "part-time" ? "selected" : ""}>Part-time</option>
            <option value="full-time" ${type === "full-time" ? "selected" : ""}>Full-time</option>
          </select>
          <button class="button" type="submit">Search</button>
        </form>

        <div class="jobs">
          ${
            jobs.length
              ? jobs
                  .map(
                    (j) => `
                      <a class="job" href="/jobs/${j._id}">
                        <div class="job__top">
                          <div class="job__title">${j.title}</div>
                          <span class="badge">${j.type}</span>
                        </div>
                        <div class="job__meta">
                          <span>
                            <a href="/companies/${j.companyUserId}" style="color: inherit; text-decoration: none;">${j.companyName}</a>
                          </span>
                          <span class="dot">•</span>
                          <span>${j.location || "Remote / Flexible"}</span>
                        </div>
                      </a>
                    `
                  )
                  .join("")
              : `<div class="muted">No jobs found.</div>`
          }
        </div>
      </section>
    `,
  })
%>

