<%-
  include("../layout", {
    title,
    currentUser,
    body: `
      <section class="page">
        <div class="row row--between">
          <div>
            <h1>Company dashboard</h1>
            <p class="muted">Post jobs and review applications.</p>
          </div>
          <a class="button" href="/company/jobs/new">Post a job</a>
        </div>

        <div class="jobs">
          ${
            jobs.length
              ? jobs
                  .map(
                    (j) => `
                      <div class="job job--static">
                        <div class="job__top">
                          <div class="job__title">${j.title}</div>
                          <span class="badge">${j.isActive ? "active" : "inactive"}</span>
                        </div>
                        <div class="job__meta">
                          <span>${j.type}</span>
                          <span class="dot">•</span>
                          <span>${j.location || "Remote / Flexible"}</span>
                        </div>
                        <div class="row row--gap" style="margin-top: 10px;">
                          <a class="button button--ghost" href="/jobs/${j._id}">View</a>
                          <a class="button button--ghost" href="/company/jobs/${j._id}/applications">Applications</a>
                          <a class="button button--ghost" href="/company/jobs/${j._id}/edit">Edit</a>
                          <form method="post" action="/company/jobs/${j._id}/toggle" style="display: inline;">
                            <button class="button button--ghost" type="submit">${j.isActive ? "Disable" : "Enable"}</button>
                          </form>
                          <form method="post" action="/company/jobs/${j._id}/delete" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this job?');">
                            <button class="button button--ghost" style="color: #d32f2f;" type="submit">Delete</button>
                          </form>
                        </div>
                      </div>
                    `
                  )
                  .join("")
              : `<div class="muted">No jobs yet. Click “Post a job”.</div>`
          }
        </div>
      </section>
    `,
  })
%>

